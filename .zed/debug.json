[
  {
    "label": "TUI",
    "adapter": "Debugpy",
    "request": "launch",
    "module": "tempo_cli",
    "args": [
      "tui"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "justMyCode": false
  },
  {
    "label": "Serve Docs",
    "adapter": "Debugpy",
    "request": "launch",
    "module": "mkdocs",
    "args": [
      "serve",
      "--livereload"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "justMyCode": false
  },
  {
    "label": "Test Zedfest Modding Kit Project",
    "adapter": "Debugpy",
    "request": "launch",
    "module": "tempo_cli",
    "args": [
      "run",
      "test_mods_all",
      "--settings_json",
      ".tempo.json"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/../ZedfestModdingKit",
    "justMyCode": false
  },
  {
    "label": "Test Init",
    "adapter": "Debugpy",
    "request": "launch",
    "module": "tempo_cli",
    "args": [
      "init",
      "--directory",
      "C:/Users/mythi/Downloads/testing"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "justMyCode": false
  }
]
